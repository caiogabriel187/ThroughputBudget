{
  "expo": {
    "name": "Calculadora 5G NR",
    "slug": "calculadora-5g-nr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0066cc",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.calculadora5gnr"
    },
    "android": {
      "package": "com.calculadora5gnr",
      "edgeToEdgeEnabled": false,
      "permissions": ["INTERNET"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ]
  }
}
